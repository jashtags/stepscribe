# LLM backend: "ollama" (default, free) or "anthropic" (paid, higher quality)
LLM_BACKEND=ollama

# Ollama settings (used when LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2-vision:11b
OLLAMA_TEXT_MODEL=llama3.2:3b

# Anthropic settings (used when LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Whisper settings (tiny/base/small/medium/large)
WHISPER_MODEL=small

# Optional features
ENABLE_OCR=false

# Cleanup media files after successful processing
CLEANUP_AFTER_SUCCESS=true

# Performance tuning
MAX_KEYFRAMES=30
SCENE_THRESHOLD=0.3
